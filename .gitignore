# Ignore IDE settings and local junk
.vs/
.vscode/
.idea/
*.csproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svclog
*.pdb
*.mdb
*.opendb
*.db
*.VC.db

# Ignore OS generated files
.DS_Store
